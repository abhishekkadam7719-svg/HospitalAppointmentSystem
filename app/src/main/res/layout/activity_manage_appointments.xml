<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F9FC"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1565C0"
        android:padding="20dp"
        android:paddingTop="45dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage Appointments"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Review and update appointment status"
            android:textColor="#D6E4F5"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Search -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp">

        <EditText
            android:id="@+id/etSearchAppointment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:hint="Search by patient or doctor"
            android:padding="14dp"
            android:textSize="14sp" />

    </androidx.cardview.widget.CardView>

    <!-- Filter Tabs (TextViews acting as pill buttons) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/btnAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="All"
                android:textColor="#5C6B7A"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnPending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Pending"
                android:textColor="#5C6B7A"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnApproved"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Approved"
                android:textColor="#5C6B7A"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnRejected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Rejected"
                android:textColor="#5C6B7A"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Appointment List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAppointments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:clipToPadding="false" />

</LinearLayout>